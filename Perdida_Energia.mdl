{UTF-8}
Subsidio Estatal BESS=(Tasa Expansión ERNC * (Factor de Energía Generada / Factor de Absorción BESS\
		)) + (Tasa de Vertimiento
	 * 0.05)
	~	MW/mes
	~		|

Factor de Energía Generada=0.72
	~	GWh/mes
	~		|

Generación Excedente=MAX ( 0 , (Capacidad ERNC Instalada * Factor de Energía Generada\
		) - Demanda del Sistema - Capacidad de Transmisión )
	~	GWh/mes
	~		|

Factor de Absorción BESS=0.12
	~	GWh/mes
	~		|

Tasa de Vertimiento=MAX ( 0 , Generación Excedente - (Capacidad BESS Instalada * Factor de Absorción BESS\
		) )
	~	GWh/mes
	~		|

Capacidad BESS Instalada= INTEG (Tasa de Inversión BESS,
		1575)
	~	MW
	~		|

Capacidad de Transmisión=1800
	~	GWh/mes
	~		|

Capacidad ERNC Instalada= INTEG (Tasa Expansión ERNC,
		18523)
	~	MW
	~		|

Demanda del Sistema=6395
	~	GWh/mes
	~		|

Energía Vertida Acumulada= INTEG (Tasa de Vertimiento,
		5642)
	~	GWh
	~		|

Factor Incentivo BESS=MIN(3, Pérdida de Rentabilidad / 1e+07)
	~	GWh/(MW*mes)
	~		|

Pérdida de Rentabilidad=Tasa de Vertimiento * 62821
	~	$USD
	~		|

Tasa de Inversión BESS=(Factor Incentivo BESS * 15) + Subsidio Estatal BESS
	~	MW/mes
	~		|

Tasa Expansión ERNC=150 / (1 + (Pérdida de Rentabilidad / 5e+07))
	~	GWh/(MW*mes)
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 72
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

