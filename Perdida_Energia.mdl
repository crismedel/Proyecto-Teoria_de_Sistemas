Factor de Energía Generada=0.72
	~	GWh/mes
	~		|

Generación Excedente=MAX ( 0 , (Capacidad ERNC Instalada * Factor de Energía Generada\
		) - Demanda del Sistema - Capacidad de Transmisión )
	~	GWh/mes
	~		|

Factor de Absorción BESS=0.12
	~	GWh/mes
	~		|

Tasa de Vertimiento=MAX ( 0 , Generación Excedente - (Capacidad BESS Instalada * Factor de Absorción BESS\
		) )
	~	GWh/mes
	~		|

Capacidad BESS Instalada= INTEG (Tasa de Inversión BESS,
		1575)
	~	MW
	~		|

Capacidad de Transmisión=1800
	~	GWh/mes
	~		|

Capacidad ERNC Instalada= INTEG (Tasa Expansión ERNC,
		18523)
	~	MW
	~		|

Demanda del Sistema=6395
	~	GWh/mes
	~		|

Energía Vertida Acumulada= INTEG (Tasa de Vertimiento,
		5642)
	~	GWh
	~		|

Factor Incentivo BESS=Pérdida de Rentabilidad / 1e+07
	~	GWh/(MW*mes)
	~		|

Pérdida de Rentabilidad=Tasa de Vertimiento * 62821
	~	$USD
	~		|

Subsidio Estatal BESS=STEP(300, 24)
	~	MW/mes
	~		|

Tasa de Inversión BESS=(Factor Incentivo BESS * 10) + Subsidio Estatal BESS
	~	MW/mes
	~		|

Tasa Expansión ERNC=MAX (0, 150 - (Pérdida de Rentabilidad * 5e-06))
	~	GWh/(MW*mes)
	~		|

