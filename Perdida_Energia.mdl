	~	GWh/mes
	~		|

Energía Vertida Acumulada= INTEG (Tasa de Vertimiento,
		5642)
	~	GWh
	~		|

Factor Incentivo BESS=MIN(3, Pérdida de Rentabilidad / 1e+07)
	~	
	~		|

Generación Excedente=MAX ( 0 , (Capacidad ERNC Instalada * 0.5) - Demanda del Sistema\
		 - Capacidad de Transmisión )
	~	GWh/mes
	~		|

Pérdida de Rentabilidad=Tasa de Vertimiento * 62821
	~	$USD
	~		|

Subsidio Estatal BESS=STEP(150, 24)
	~	MW/mes
	~		|

Tasa de Inversión BESS=10 + (Factor Incentivo BESS * 50) + Subsidio Estatal BESS
	~	MW/mes
	~		|

Tasa de Vertimiento=MAX ( 0 , Generación Excedente - (Capacidad BESS Instalada * 0.5\
		) )
	~	GWh/mes
	~		|

Tasa Expansión ERNC=150 / (1 + (Pérdida de Rentabilidad / 50000000))
	~	
	~		|

