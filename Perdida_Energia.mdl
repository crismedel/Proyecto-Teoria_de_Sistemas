{UTF-8}
Tasa de Inversión BESS=MIN(100, Factor Incentivo BESS * 50)
	~	MW/mes
	~		|

Capacidad BESS Instalada= INTEG (Tasa de Inversión BESS,
		1575)
	~	MW
	~		|

Capacidad de Transmisión=2500
	~	GWh/mes
	~		|

Capacidad ERNC Instalada= INTEG (Tasa Expansión ERNC,
		18471)
	~	MW
	~		|

Demanda del Sistema=3050.05
	~	GWh/mes
	~		|

Energía Vertida Acumulada= INTEG (Tasa de Vertimiento,
		5642)
	~	GWh
	~		|

Factor Incentivo BESS=Pérdida de Rentabilidad / 1e+07
	~	
	~		|

Generación Excedente=MAX ( 0 , (Capacidad ERNC Instalada * 0.5) - Demanda del Sistema\
		 - Capacidad de Transmisión )
	~	GWh/mes
	~		|

Pérdida de Rentabilidad=Tasa de Vertimiento * 62821.4
	~	$USD
	~		|

Tasa de Vertimiento=MAX ( 0 , Generación Excedente - (Capacidad BESS Instalada * 0.5\
		) )
	~	GWh/mes
	~		|

Tasa Expansión ERNC=MAX ( 0 , 150 - (Pérdida de Rentabilidad * 0.0001) )
	~	
	~		|

